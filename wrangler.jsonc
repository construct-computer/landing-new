{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "landing-new",
  "main": "worker.ts",
  "compatibility_date": "2026-04-23",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "dist",
    "binding": "ASSETS",
    "not_found_handling": "404-page",
    "html_handling": "force-trailing-slash",
    "run_worker_first": true
  }
}
